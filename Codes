# Test tail causes-------------------------------------------
set.seed(42)
n <- 50000

## Set indexes, log() and sd(log)----------------------------
mu_ln <- log(pair1_sorted)
sigma_ln <- sd(log(pair1_sorted))

## Set continuous intervals----------------------------------
int1_cont <- rlnorm(n, meanlog = mu_ln, sdlog = sigma_ln)
int2_cont <- rlnorm(n, meanlog = mu_ln, sdlog = sigma_ln)

df_cont <- data.frame(
  cd = int1_cont + int2_cont,
  rr = int1_cont / (int1_cont + int2_cont),
  type = "Continuous"
)

## Set integer intervals-------------------------------------
int1_int <- round(rlnorm(n, meanlog = mu_ln, sdlog = sigma_ln))
int2_int <- round(rlnorm(n, meanlog = mu_ln, sdlog = sigma_ln))

## Delete 0
keep <- int1_int > 0 & int2_int > 0
int1_int <- int1_int[keep]
int2_int <- int2_int[keep]

df_int <- data.frame(
  cd_test = int1_int + int2_int,
  rr_test = int1_int / (int1_int + int2_int),
  type = "Integer"
)

## Plot
plot_test <- function(df, title) {
  ggplot(df, aes(x = rr_test, y = cd_test)) +
    geom_point(size = 0.01, alpha = 0.05) +
    scale_x_continuous(limits = c(0, 1), breaks = seq(0, 1, 0.2)) +
    scale_y_continuous(limits = c(0, 400), breaks = seq(0, 400, 100)) +
    labs(title = title, x = "ratio rhythm", y = "cycle duration (ms)") +
    theme_classic()
  }

p1_con <- plot_test(df_cont, "Continuous intervals")
p2_int <- plot_test(df_int,  "Integer intervals (1ms resolution)")
p1_con 
p2_int


